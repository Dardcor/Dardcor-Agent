// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`DARDCOR CLI help-text snapshots every documented command emits stable help text: DARDCOR acp --help 1`] = `
"DARDCOR acp

start ACP (Agent Client Protocol) server

Options:
  -h, --help         show help                                                             [boolean]
  -v, --version      show version number                                                   [boolean]
      --print-logs   print logs to stderr                                                  [boolean]
      --log-level    log level                  [string] [choices: "DEBUG", "INFO", "WARN", "ERROR"]
      --pure         run without external plugins                                          [boolean]
      --port         port to listen on                                         [number] [default: 0]
      --hostname     hostname to listen on                           [string] [default: "127.0.0.1"]
      --mdns         enable mDNS service discovery (defaults hostname to 0.0.0.0)
                                                                          [boolean] [default: false]
      --mdns-domain  custom domain name for mDNS service (default: DARDCOR.local)
                                                                [string] [default: "DARDCOR.local"]
      --cors         additional domains to allow for CORS                      [array] [default: []]
      --cwd          working directory [string] [default: "<HOME>"]"
`;

exports[`DARDCOR CLI help-text snapshots every documented command emits stable help text: DARDCOR mcp --help 1`] = `
"DARDCOR mcp

manage MCP (Model Context Protocol) servers

Commands:
  DARDCOR mcp add [name]     add an MCP server
  DARDCOR mcp list           list MCP servers and their status                        [aliases: ls]
  DARDCOR mcp auth [name]    authenticate with an OAuth-enabled MCP server
  DARDCOR mcp logout [name]  remove OAuth credentials for an MCP server
  DARDCOR mcp debug <name>   debug OAuth connection for an MCP server

Options:
  -h, --help        show help                                                              [boolean]
  -v, --version     show version number                                                    [boolean]
      --print-logs  print logs to stderr                                                   [boolean]
      --log-level   log level                   [string] [choices: "DEBUG", "INFO", "WARN", "ERROR"]
      --pure        run without external plugins                                           [boolean]"
`;

exports[`DARDCOR CLI help-text snapshots every documented command emits stable help text: DARDCOR attach --help 1`] = `
"DARDCOR attach <url>

attach to a running DARDCOR server

Positionals:
  url  http://localhost:4096                                                     [string] [required]

Options:
  -h, --help          show help                                                            [boolean]
  -v, --version       show version number                                                  [boolean]
      --print-logs    print logs to stderr                                                 [boolean]
      --log-level     log level                 [string] [choices: "DEBUG", "INFO", "WARN", "ERROR"]
      --pure          run without external plugins                                         [boolean]
      --dir           directory to run in                                                   [string]
  -c, --continue      continue the last session                                            [boolean]
  -s, --session       session id to continue                                                [string]
      --fork          fork the session when continuing (use with --continue or --session)  [boolean]
  -p, --password      basic auth password (defaults to DARDCOR_SERVER_PASSWORD)            [string]
  -u, --username      basic auth username (defaults to DARDCOR_SERVER_USERNAME or 'DARDCOR')
                                                                                            [string]
      --mini          start the minimal interactive interface             [boolean] [default: false]
      --no-replay     disable mini session history replay on resume and after resize       [boolean]
      --replay-limit  cap visible mini replay to the newest N messages                      [number]"
`;

exports[`DARDCOR CLI help-text snapshots every documented command emits stable help text: DARDCOR run --help 1`] = `
"DARDCOR run [message..]

run DARDCOR with a message

Positionals:
  message  message to send                                                     [array] [default: []]

Options:
  -h, --help         show help                                                             [boolean]
  -v, --version      show version number                                                   [boolean]
      --print-logs   print logs to stderr                                                  [boolean]
      --log-level    log level                  [string] [choices: "DEBUG", "INFO", "WARN", "ERROR"]
      --pure         run without external plugins                                          [boolean]
      --command      the command to run, use message for args                               [string]
  -c, --continue     continue the last session                                             [boolean]
  -s, --session      session id to continue                                                 [string]
      --fork         fork the session before continuing (requires --continue or --session) [boolean]
      --share        share the session                                                     [boolean]
  -m, --model        model to use in the format of provider/model                           [string]
      --agent        agent to use                                                           [string]
      --format       format: default (formatted) or json (raw JSON events)
                                          [string] [choices: "default", "json"] [default: "default"]
  -f, --file         file(s) to attach to message                                            [array]
      --title        title for the session (uses truncated prompt if no value provided)     [string]
      --attach       attach to a running DARDCOR server (e.g., http://localhost:4096)      [string]
  -p, --password     basic auth password (defaults to DARDCOR_SERVER_PASSWORD)             [string]
  -u, --username     basic auth username (defaults to DARDCOR_SERVER_USERNAME or 'DARDCOR')
                                                                                            [string]
      --dir          directory to run in, path on remote server if attaching                [string]
      --port         port for the local server (defaults to random port if no value provided)
                                                                                            [number]
      --variant      model variant (provider-specific reasoning effort, e.g., high, max, minimal)
                                                                                            [string]
      --thinking     show thinking blocks                                                  [boolean]
  -i, --interactive  run in direct interactive split-footer mode          [boolean] [default: false]
      --auto         auto-approve permissions that are not explicitly denied (dangerous!)
                                                                          [boolean] [default: false]"
`;

exports[`DARDCOR CLI help-text snapshots every documented command emits stable help text: DARDCOR debug --help 1`] = `
"DARDCOR debug

debugging and troubleshooting tools

Commands:
  DARDCOR debug config        show resolved configuration
  DARDCOR debug lsp           LSP debugging utilities
  DARDCOR debug rg            ripgrep debugging utilities
  DARDCOR debug file          file system debugging utilities
  DARDCOR debug scrap         list all known projects
  DARDCOR debug skill         list all available skills
  DARDCOR debug snapshot      snapshot debugging utilities
  DARDCOR debug startup       print startup timing
  DARDCOR debug agent <name>  show agent configuration details
  DARDCOR debug v2            debug v2 catalog and built-in plugins
  DARDCOR debug info          show debug information
  DARDCOR debug paths         show global paths (data, config, cache, state)
  DARDCOR debug wait          wait indefinitely (for debugging)

Options:
  -h, --help        show help                                                              [boolean]
  -v, --version     show version number                                                    [boolean]
      --print-logs  print logs to stderr                                                   [boolean]
      --log-level   log level                   [string] [choices: "DEBUG", "INFO", "WARN", "ERROR"]
      --pure        run without external plugins                                           [boolean]"
`;

