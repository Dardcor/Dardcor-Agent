{
  "name": "dardcor-agent",
  "version": "1.0.12",
  "preferGlobal": true,
  "private": false,
  "type": "module",
  "bin": {
    "dardcor": "cli.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "dardcor run",
    "prepack": "npm run build",
    "postinstall": "node -e \"const fs = require('fs'); const dirs = ['database', 'database/model/antigravity']; dirs.forEach(d => { if (!fs.existsSync(d)) fs.mkdirSync(d, { recursive: true }); })\""
  },
  "description": "Autonomous AI Agent — Gateway, CLI TUI, Multi-Provider LLM, Skills",
  "keywords": [
    "ai",
    "agent",
    "autonomous",
    "dashboard",
    "cli",
    "tui",
    "openai",
    "claude",
    "gemini",
    "deepseek",
    "ollama",
    "dardcor",
    "coding-agent",
    "terminal"
  ],
  "author": "Dardcor Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dardcor/dardcor-agent.git"
  },
  "bugs": {
    "url": "https://github.com/dardcor/dardcor-agent/issues"
  },
  "homepage": "https://github.com/dardcor/dardcor-agent#readme",
  "files": [
    "cli.js",
    "bin/",
    "dist/",
    "config/",
    "handlers/",
    "middleware/",
    "models/",
    "services/",
    "storage/",
    "go.mod",
    "go.sum",
    "main.go",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}